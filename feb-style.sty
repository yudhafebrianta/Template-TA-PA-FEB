\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{feb-style}[2025/01/01 v1.0 Template TA FEB Universitas Telkom (M. Yudha Febrianta)]

% -----------------------------------------------------------------------------
% PACKAGES
% -----------------------------------------------------------------------------
\RequirePackage[a4paper,
  left=4cm,        % 4 cm (termasuk 1 cm jilid)
  right=3cm,
  top=4cm,
  bottom=3cm]{geometry}

% Font: Times New Roman equivalent (pdflatex)
\RequirePackage{mathptmx}        % Times New Roman untuk teks dan math
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}

% Bahasa Indonesia
\RequirePackage[bahasa]{babel}

% Spasi 1.5
\RequirePackage{setspace}
\onehalfspacing

% Indentasi paragraf 5 karakter (≈1.27 cm untuk TNR 12pt)
\setlength{\parindent}{1.27cm}
\setlength{\parskip}{0pt}

% Indent paragraf pertama setelah heading
\RequirePackage{indentfirst}

% Header/footer custom
\RequirePackage{fancyhdr}

% Chapter/section title formatting
\RequirePackage{titlesec}

% TOC/LOT/LOF formatting
\RequirePackage{tocloft}

% Grafik dan gambar
\RequirePackage{graphicx}
\RequirePackage{float}

% Tabel
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{longtable}

% Caption
\RequirePackage{caption}

% Referensi APA 7th (authoryear menghasilkan format Author (Year) sesuai APA)
\RequirePackage[style=authoryear, backend=biber, natbib=true, dashed=false]{biblatex}

% Hyperlink (load terakhir)
\RequirePackage[hidelinks, unicode, breaklinks]{hyperref}

% Nomor halaman
\RequirePackage{ifthen}

% Untuk \cleardoublepage yang benar
\RequirePackage{emptypage}

% -----------------------------------------------------------------------------
% PAGE STYLE — FRONT MATTER (angka Romawi, tengah bawah - semua halaman)
% -----------------------------------------------------------------------------
\fancypagestyle{frontmatterstyle}{%
  \fancyhf{}
  \fancyfoot[OC]{\thepage}   % Odd  → tengah bawah
  \fancyfoot[EC]{\thepage}   % Even → tengah bawah
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}

% PAGE STYLE — BODY (angka Arab)
% Halaman ganjil: kanan bawah; halaman genap: kiri bawah
\fancypagestyle{bodystyle}{%
  \fancyhf{}
  \fancyfoot[OC]{\thepage}   % Odd  → tengah bawah
  \fancyfoot[EC]{\thepage}   % Even → tengah bawah
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}

% PAGE STYLE — Halaman pertama setiap bab (tengah bawah)
\fancypagestyle{plain}{%
  \fancyhf{}
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0pt}
}

% -----------------------------------------------------------------------------
% CHAPTER HEADING FORMAT
% BAB [ROMAN NUMERAL]
% JUDUL BAB (ALL CAPS, BOLD, CENTERED, 12pt)
% -----------------------------------------------------------------------------
\titleformat{\chapter}[display]
  {\normalfont\fontsize{12}{14}\bfseries\centering}   % format
  {BAB \thechapter}                                    % label
  {0pt}                                               % sep
  {\MakeUppercase}                                    % before-code
  []                                                  % after-code

\titlespacing*{\chapter}{0pt}{0pt}{18pt}

% Konversi nomor bab ke Romawi
\renewcommand{\thechapter}{\Roman{chapter}}

% -----------------------------------------------------------------------------
% SECTION FORMATTING
% Maks 3 level: 1.1 / 1.1.1 / 1.1.1.1
% Bold, rata kiri
% -----------------------------------------------------------------------------
\titleformat{\section}
  {\normalfont\fontsize{12}{14}\bfseries}
  {\thesection}
  {1em}{}

\titleformat{\subsection}
  {\normalfont\fontsize{12}{14}\bfseries}
  {\thesubsection}
  {1em}{}

\titleformat{\subsubsection}
  {\normalfont\fontsize{12}{14}\bfseries}
  {\thesubsubsection}
  {1em}{}

% Penomoran section menggunakan angka Arab
\renewcommand{\thesection}{\arabic{chapter}.\arabic{section}}
\renewcommand{\thesubsection}{\arabic{chapter}.\arabic{section}.\arabic{subsection}}
\renewcommand{\thesubsubsection}{\arabic{chapter}.\arabic{section}.\arabic{subsection}.\arabic{subsubsection}}

% Kedalaman TOC: tampilkan sampai subsubsection
\setcounter{tocdepth}{3}
\setcounter{secnumdepth}{3}

% -----------------------------------------------------------------------------
% TABLE OF CONTENTS FORMATTING
% Judul bab: BOLD CAPS
% -----------------------------------------------------------------------------
\renewcommand{\cftchapfont}{\bfseries}
\renewcommand{\cftchappagefont}{\bfseries}
\renewcommand{\cftchapleader}{\bfseries\cftdotfill{\cftdotsep}}

% Ubah "Contents" → "DAFTAR ISI"
\addto\captionsbahasa{%
  \renewcommand{\contentsname}{DAFTAR ISI}%
  \renewcommand{\listfigurename}{DAFTAR GAMBAR}%
  \renewcommand{\listtablename}{DAFTAR TABEL}%
  \renewcommand{\bibname}{DAFTAR PUSTAKA}%
  \renewcommand{\appendixname}{DAFTAR LAMPIRAN}%
  \renewcommand{\chaptername}{BAB}%
}

% Prefix "BAB " pada TOC untuk chapter entries
\renewcommand{\cftchappresnum}{BAB }
\renewcommand{\cftchapaftersnum}{\ }
\setlength{\cftchapnumwidth}{2cm}

% Judul DAFTAR ISI, DAFTAR TABEL, DAFTAR GAMBAR: centered, 12pt, bold
\renewcommand{\cfttoctitlefont}{\hfill\normalsize\bfseries}
\renewcommand{\cftaftertoctitle}{\hfill}
\renewcommand{\cftlottitlefont}{\hfill\normalsize\bfseries}
\renewcommand{\cftafterlottitle}{\hfill}
\renewcommand{\cftloftitlefont}{\hfill\normalsize\bfseries}
\renewcommand{\cftafterloftitle}{\hfill}

% -----------------------------------------------------------------------------
% CAPTION FORMAT
% Judul tabel: di atas, TNR 12pt, 1.5 spasi
% Judul gambar: di bawah, TNR 12pt, 1.5 spasi
% Isi tabel: TNR 10pt, spasi 1.15
% -----------------------------------------------------------------------------
\captionsetup[table]{
  position=above,
  font={normalsize},
  labelsep=space,
  justification=raggedright,
  singlelinecheck=false
}

\captionsetup[figure]{
  position=below,
  font={normalsize},
  labelsep=space,
  justification=centering
}

% Format nomor tabel: Tabel 1.1, Tabel 2.1, dst.
\renewcommand{\thetable}{\arabic{chapter}.\arabic{table}}
\renewcommand{\thefigure}{\arabic{chapter}.\arabic{figure}}

% -----------------------------------------------------------------------------
% ABSTRACT ENVIRONMENT (spasi 1, TNR 12pt)
% -----------------------------------------------------------------------------
\newenvironment{abstrakenv}{%
  \begin{singlespace}%
  \setlength{\parindent}{1.27cm}%
}{%
  \end{singlespace}%
}

% -----------------------------------------------------------------------------
% DAFTAR LAMPIRAN
% -----------------------------------------------------------------------------
\newlistof{lampiran}{lol}{DAFTAR LAMPIRAN}
\newcommand{\addlampiran}[1]{%
  \refstepcounter{lampiran}%
  \addcontentsline{lol}{lampiran}{\protect\numberline{Lampiran \thelampiran}#1}%
}

% -----------------------------------------------------------------------------
% PERINTAH UTILITAS
% -----------------------------------------------------------------------------

% Halaman baru selalu di halaman ganjil (untuk awal bab)
\newcommand{\babBaru}{%
  \cleardoublepage%
}

% Lingkungan isi tabel (TNR 10pt, spasi 1.15)
\newenvironment{isitable}{%
  \fontsize{10}{11.5}\selectfont%
  \setstretch{1.15}%
}{%
  \fontsize{12}{14}\selectfont%
  \onehalfspacing%
}

\endinput
